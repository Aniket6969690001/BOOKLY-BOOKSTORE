@model EBook.Models.EditProfileViewModel
@{
    Layout = "~/Views/Shared/_Profile.cshtml";
    ViewData["Title"] = "Profile";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="max-w-2xl mx-auto bg-white shadow-sm">
        <header class="flex items-center justify-between px-6 py-3 border-b">
            <h1 class="text-xl font-semibold">Edit Profile</h1>
        </header>

        <div class="px-6 py-4">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="bg-blue-100 text-blue-800 p-3 rounded-lg mb-4">
                    @TempData["SuccessMessage"]
                </div>
            }

            <form asp-action="EditProfile" method="post" class="space-y-4">
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Username</label>
                    <input type="text" name="Username" value="@Model.Username" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Full Name</label>
                    <input type="text" name="FullName" value="@Model.FullName" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Email</label>
                    <input type="email" name="Email" value="@Model.Email" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Phone Number</label>
                    <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Address</label>
                    <input type="text" name="Address" value="@Model.Address" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Pincode</label>
                    <input type="text" name="Pincode" value="@Model.Pincode" class="w-full h-10 border-b focus:border-primary outline-none">
                </div>

                <div>
                    <button type="submit" class="bg-[#457b9d] text-white py-2 px-4 rounded-lg hover:bg-[#3b78c1]">
                        Save Changes
                    </button>

                </div>
            </form>
        </div>
    </div>
</body>
</html>