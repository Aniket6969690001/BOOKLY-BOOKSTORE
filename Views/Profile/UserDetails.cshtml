@model EBook.Model.RegistrationTable
@{
    Layout = "~/Views/Shared/_Profile.cshtml";
    ViewData["Title"] = "Profile";
}
<style>
    .profile-container {
        max-width: 80%; /* Increase width to 80% */
        margin: 30px auto;
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
    }


    .profile-title {
        font-size: 28px;
        font-weight: bold;
        text-align: center;
        margin-bottom: 20px;
        color: #2c3e50;
    }

    .profile-table {
        width: 100%;
        font-size: 18px;
        border-collapse: collapse; /* Ensures borders align properly */
    }

        .profile-table th,
        .profile-table td {
            padding: 12px 15px;
            text-align: left;
        }

        .profile-table th {
            width: 30%;
            background: #f5f5f5;
            font-weight: bold;
        }

        .profile-table td {
            width: 70%;
            background: #ffffff;
        }

        /* Add bottom borders between rows */
        .profile-table tr {
            border-bottom: 1px solid #ddd;
        }

            /* Last row shouldn't have a border */
            .profile-table tr:last-child {
                border-bottom: none;
            }
</style>


<div class="profile-container">
    <h2 class="profile-title">User details</h2>

    <table class="profile-table">
        <tr>
            <th>Username:</th>
            <td>@Model.Username</td>
        </tr>
        <tr>
            <th>Full Name:</th>
            <td>@Model.FullName</td>
        </tr>
        <tr>
            <th>Email:</th>
            <td>@Model.Email</td>
        </tr>
        <tr>
            <th>Phone Number:</th>
            <td>@Model.Mobile</td>
        </tr>
        <tr>
            <th>Address:</th>
            <td>@Model.Address</td>
        </tr>
        <tr>
            <th>Pincode:</th>
            <td>@Model.Pincode</td>
        </tr>
    </table>
</div>