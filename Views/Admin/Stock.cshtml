@model IEnumerable<EBook.Models.StockViewModel>

@{
    Layout = "~/Views/Shared/_Admin.cshtml";
    ViewData["Title"] = "Stock";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        body {
            background-color: #f4f6f9;
        }

        .main-content {
            padding: 20px;
        }

        .table-container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .btn-primary {
            background-color: #4a90e2;
            border-color: #4a90e2;
        }

            .btn-primary:hover {
                background-color: black;
                border-color: black;
            }

        .btn-cancel {
            border: 1px solid black;
            color: black;
            background-color: white;
        }

            .btn-cancel:hover {
                background-color: black;
                color: white;
            }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
        }
    </style>
</head>
<body>
    <div class="main-content">
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold">Stocks</h3>
            </div>

            <div class="input-group mb-4 w-50">
                <input type="text" id="searchBox" class="form-control" placeholder="Search by book" onkeyup="searchStock()" />
                <button class="btn btn-primary ms-2" onclick="searchStock()">Find</button>
                <button class="btn btn-cancel ms-2" onclick="clearSearch()">Clear</button>
            </div>

            <div class="table-container">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Book</th>
                                <th>Stock</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="stockTable">
                            @{
                                int count = 1;
                            }
                            @foreach (var stock in Model)
                            {
                                <tr id="row-@stock.Id">
                                    <td>@count</td>
                                    <td>@stock.BookName</td>
                                    <td>@stock.Quantity</td>
                                    <td>
                                        <button class="btn btn-outline-primary btn-sm openModalBtn"
                                                data-id="@stock.Id"
                                                data-quantity="@stock.Quantity"
                                                data-book="@stock.BookName">
                                            Update
                                        </button>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No stock data available.</p>
                }
            </div>
        </div>
    </div>

    <!-- Modal for Updating Stock -->
    <div class="modal fade" id="stockModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Update Stock</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="stockForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="modalStockId" />
                        <div class="mb-3">
                            <label class="form-label">Book Name</label>
                            <input type="text" class="form-control" id="modalBookName" readonly />
                        </div>
                        <div class="mb-3">
                            <label for="modalStockQuantity" class="form-label">Quantity</label>
                            <input type="number" class="form-control" id="modalStockQuantity" required min="0" />
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function searchStock() {
            let input = document.getElementById("searchBox").value.toLowerCase().trim();
            let rows = document.querySelectorAll("#stockTable tr");

            rows.forEach(row => {
                let bookName = row.cells[1]?.innerText.toLowerCase().trim();
                row.style.display = bookName.includes(input) ? "" : "none";
            });
        }

        function clearSearch() {
            document.getElementById("searchBox").value = "";
            searchStock();
        }


                    $(document).ready(function () {
            var stockModal = new bootstrap.Modal(document.getElementById('stockModal'));

            $(".openModalBtn").click(function () {
                let stockId = $(this).data("id");
                let quantity = $(this).data("quantity");
                let book = $(this).data("book");

                $("#modalStockId").val(stockId);
                $("#modalStockQuantity").val(quantity);
                $("#modalBookName").val(book);

                stockModal.show();
            });

        

        // Replace your current form submit handler with this:
        $("#stockForm").submit(function (e) {
            e.preventDefault();

            const stockId = parseInt($("#modalStockId").val());
            const quantity = parseInt($("#modalStockQuantity").val());
            const token = $('input[name="__RequestVerificationToken"]').val();

            // Validation
            if (isNaN(quantity)) {
                alert("Please enter a valid number for quantity.");
                return;
            }

            if (quantity < 0) {
                alert("Quantity cannot be negative.");
                return;
            }

            $.ajax({
                url: '/Admin/UpdateStock', // Make sure this matches your controller route
                type: 'POST',
                headers: {
                    "RequestVerificationToken": token,
                    "Content-Type": "application/json"
                },
                data: JSON.stringify({
                    Id: stockId,
                    Quantity: quantity
                }),
                success: function (result) {
                    if (result.success) {
                        alert("Stock updated successfully!");
                        location.reload();
                    } else {
                        alert("Error: " + result.message);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error:", error);
                    alert("Something went wrong! Please try again.");
                }
            });
        });


        });
    </script>
</body>
</html>