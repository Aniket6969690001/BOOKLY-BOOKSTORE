@model EBook.Models.GenreViewModel

@{
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Genres</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        body {
            background-color: #f4f6f9;
        }

        .main-content {
            padding: 20px;
        }

        .table-container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .btn-primary {
            background-color: #4a90e2;
            border-color: #4a90e2;
        }

            .btn-primary:hover {
                background-color: black;
                border-color: black;
            }

        .btn-cancel {
            border: 1px solid black;
            color: black;
            background-color: white;
        }

            .btn-cancel:hover {
                background-color: black;
                color: white;
            }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
        }
    </style>
</head>
<body>
    <div class="main-content">
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold">Genres</h3>
                <button class="btn btn-primary" id="addGenreBtn">Add Genre</button>
            </div>
            <div class="table-container">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Genre</th>
                            <th>Book Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="genreTable">
                        @{
                            int count = 1;
                        }
                        @foreach (var genre in Model.Genres)
                        {
                            <tr>
                                <td>@count</td>
                                <td class="genreName">@genre.GenreName</td>
                                <td>@genre.BookCount</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm editBtn" data-id="@genre.Id" data-name="@genre.GenreName">Edit</button>
                                    <button class="btn btn-outline-danger btn-sm deleteBtn" data-id="@genre.Id">Delete</button>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal for Add/Edit Genre -->
    <div class="modal fade" id="genreModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Add Genre</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="genreForm">
                        <input type="hidden" id="genreId">
                        <div class="mb-3">

                            <input type="text" class="form-control" id="genreName" placeholder="Genre Name" required>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            var genreModal = new bootstrap.Modal(document.getElementById('genreModal'));

            $("#addGenreBtn").click(function () {
                $("#modalTitle").text("Add Genre");
                $("#genreId").val('');
                $("#genreName").val('');
                genreModal.show();
            });

            $("#genreTable").on("click", ".editBtn", function () {
                var id = $(this).data("id");
                var name = $(this).data("name");
                $("#modalTitle").text("Edit Genre");
                $("#genreId").val(id);
                $("#genreName").val(name);
                genreModal.show();
            });

            $("#genreForm").submit(function (e) {
                e.preventDefault();
                var id = $("#genreId").val();
                var genreName = $("#genreName").val();
                var url = id ? '/Admin/EditGenre' : '/Admin/AddGenre';

                $.post(url, { id: id, genreName: genreName }, function (response) {
                    if (response.success) {
                        alert("Genre saved successfully!");
                        location.reload();
                    } else {
                        alert("Error saving genre.");
                    }
                });
            });

            $("#genreTable").on("click", ".deleteBtn", function () {
                var id = $(this).data("id");
                if (confirm("Are you sure you want to delete this genre?")) {
                    $.post('/Admin/DeleteGenre', { id: id }, function (response) {
                        if (response.success) {
                            alert("Genre deleted successfully!");
                            location.reload();
                        } else {
                            alert("Error deleting genre.");
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>