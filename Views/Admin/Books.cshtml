@model EBook.Models.BooksListViewModel




@{
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Books</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        body {
            background-color: #f4f6f9;
        }

        .main-content {
            padding: 20px;
        }

        .table-container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .book-img {
            width: 55px;
            height: 75px;
            object-fit: cover;
            border-radius: 5px;
        }

        .btn-primary {
            background-color: #4a90e2;
            border-color: #4a90e2;
        }

            .btn-primary:hover {
                background-color: black;
                border-color: black;
            }

        .btn-cancel {
            border: 1px solid black;
            color: black;
            background-color: white;
        }

            .btn-cancel:hover {
                background-color: black;
                color: white;
            }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
        }

        .form-label {
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="main-content">
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold">Books</h3>
            </div>

            <!-- SEARCH BAR -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div class="input-group" style="max-width: 500px;">
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by book name" onkeyup="searchBooks()">
                    <button class="btn btn-primary ms-2" type="button" onclick="searchBooks()">Find</button>
                    <button class="btn btn-cancel ms-2" type="button" onclick="clearSearch()">Clear</button>
                </div>
                <button class="btn btn-primary" id="addBookBtn">
                    <i class="bi bi-plus-circle me-1"></i> Add Book
                </button>
            </div>

            <div class="table-container">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Image</th>
                            <th>Book Name</th>
                            <th>Author</th>
                            <th>Genre</th>
                            <th>Price</th>
                            <th>Soft Copy</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="bookTable">
                        @{
                            int index = 1;
                        }
                        @foreach (var book in Model.Books)
                        {
                            <tr>
                                <td>@index</td>
                                <td><img src="/images/@book.Image" class="book-img" /></td>
                                <td class="bookName">@book.BookName</td>
                                <td>@book.AuthorName</td>
                                <td>@book.GenreName</td>

                                <td>₹@book.Price</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(book.SoftCopy))
                                    {
                                        <a href="/softcopies/@book.SoftCopy" class="btn btn-sm btn-outline-primary" target="_blank">Download</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Soft Copy</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-outline-primary btn-sm editBtn"
                                                data-id="@book.Id"
                                                data-name="@book.BookName"
                                                data-author="@book.AuthorName"
                                                data-price="@book.Price"
                                                data-genre="@book.GenreId"
                                                data-image="@book.Image">
                                            Edit
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm deleteBtn" data-id="@book.Id">Delete</button>
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal for Add/Edit Book -->
    <div class="modal fade" id="bookModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="bookForm" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title" id="bookModalTitle">Add Book</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" asp-for="Book.Id" id="bookId" name="Id" />

                        <div class="mb-2">
                            <input type="text" class="form-control" asp-for="Book.BookName" name="BookName" id="bookName" placeholder="Book Name" required />
                        </div>
                        <div class="mb-2">
                            <input type="text" class="form-control" asp-for="Book.AuthorName" name="AuthorName" id="authorName" placeholder="Author" required />
                        </div>
                        <div class="mb-2">
                            <select class="form-control" asp-for="Book.GenreId" id="genreId" name="GenreId" required>
                                <option disabled selected>Select Genre</option>
                                @foreach (var genre in Model.Genres)
                                {
                                    <option value="@genre.Id">@genre.GenreName</option>
                                }
                            </select>
                        </div>
                        <div class="mb-2">
                            <input type="number" class="form-control" asp-for="Book.Price" name="Price" id="price" placeholder="Price" required />
                        </div>
                        <div class="mb-2">
                            <textarea class="form-control" asp-for="Book.Description" name="Description" id="description" placeholder="Description"></textarea>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Book Image</label>
                            <input type="file" class="form-control" name="Image" id="bookImage" accept="image/*" />
                            <img id="previewImage" class="book-img mt-2" style="display: none;" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Soft Copy (PDF)</label>
                            <input type="file" class="form-control" name="SoftCopy" id="softCopy" accept=".pdf" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function searchBooks() {
            let input = document.getElementById("searchInput").value.toLowerCase().trim();
            let rows = document.querySelectorAll("#bookTable tr");

            rows.forEach(row => {
                let bookName = row.querySelector(".bookName")?.innerText.toLowerCase().trim();
                let genre = row.children[4]?.innerText.toLowerCase().trim();

                if (bookName.includes(input) || genre.includes(input)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function clearSearch() {
            document.getElementById("searchInput").value = "";
            searchBooks();
        }

        var bookModal = new bootstrap.Modal(document.getElementById('bookModal'));

        $("#addBookBtn").click(function () {
            $("#bookModalTitle").text("Add Book");
            $("#bookForm")[0].reset();
            $("#bookId").val('');
            $("#previewImage").hide().attr("src", "");
            bookModal.show();
        });

        // Use event delegation for dynamic buttons
        $(document).on("click", ".editBtn", function () {
            $("#bookModalTitle").text("Edit Book");
            $("#bookId").val($(this).data("id"));
            $("#bookName").val($(this).data("name"));
            $("#authorName").val($(this).data("author"));
            $("#price").val($(this).data("price"));
            $("#genreId").val($(this).data("genre"));

            const image = $(this).data("image");
            if (image) {
                $("#previewImage").attr("src", "/images/" + image).show();
            } else {
                $("#previewImage").hide();
            }

            bookModal.show();
        });

        $(document).on("click", ".deleteBtn", function () {
            if (!confirm("Are you sure you want to delete this book?")) return;
            var id = $(this).data("id");

            $.post('/Admin/DeleteBook', { id: id }, function (response) {
                alert(response.message);
                if (response.success) location.reload();
            }).fail(function () {
                alert("Error deleting book.");
            });
        });

        $("#bookForm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);
            var isEdit = $("#bookId").val();
            var url = isEdit ? '/Admin/UpdateBook' : '/Admin/SaveBook';

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    alert(response.message);
                    if (response.success) location.reload();
                },
                error: function (xhr) {
                    alert("Error: " + xhr.responseText);
                }
            });
        });
    </script>
</body>
</html>