@model List<BookWishlistViewModel>

@{
    ViewData["Title"] = "Wishlist";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>My Wishlist</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .card {
            margin-top: 100px;
            border-radius: 12px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
            background-color: #fff;
        }

        .card-header {
            background-color: #f8f9fa;
            font-weight: 600;
            font-size: 1.25rem;
            border-bottom: 1px solid #dee2e6;
            padding: 1rem 1.25rem;
        }

        .card-body {
            padding: 1.5rem;
        }

        .table img {
            max-width: 70px;
            max-height: 100px;
            object-fit: contain;
            border-radius: 6px;
        }

        .table td,
        .table th {
            vertical-align: middle !important;
        }

        .btn {
            font-size: 0.85rem;
            padding: 0.35rem 0.75rem;
            background-color: white;
            border: 1px solid black;
            color: black;
            transition: background-color 0.3s, color 0.3s, border-color 0.3s;
        }

        .btn-primary {
            border-color: #007bff;
        }

            .btn-primary:hover {
                background-color: #007bff;
                border-color: #007bff;
                color: white;
            }

        .btn-danger {
            border-color: #dc3545;
        }

            .btn-danger:hover {
                background-color: #dc3545;
                border-color: #dc3545;
                color: white;
            }

        .button-group {
            display: flex;
            justify-content: flex-start; /* Align buttons to the left */
            gap: 10px; /* Space between buttons */
        }


        .alert i {
            font-size: 48px;
            color: #888;
        }

        .empty-wishlist {
            text-align: center;
            padding: 40px 0;
            color: #555;
        }
    </style>
</head>
<body>
    <div class="container my-5">
        <div class="card">
            <div class="card-header">
                My Wishlist
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Book</th>
                                    <th>Author</th>
                                    <th>Price</th>
                                    <th style="width: 180px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var fileName = item.Image?.Trim() ?? "";
                                    var safeFileName = Uri.EscapeUriString(fileName).Replace(" ", "%20");
                                    var imagePath = !string.IsNullOrWhiteSpace(fileName)
                                    ? Url.Content($"~/images/{safeFileName}")
                                    : Url.Content("~/images/default.jpg");

                                    <tr id="wishlist-item-@item.BookId">
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@imagePath" alt="@item.BookName" />
                                                <strong>@item.BookName</strong>
                                            </div>
                                        </td>
                                        <td>@item.AuthorName</td>
                                        <td>₹@item.Price</td>
                                        <td>
                                            <div class="button-group d-flex gap-3">
                                                <button class="btn btn-sm btn-primary" onclick="addToCart(@item.BookId)">
                                                    <i class="bx bx-cart-alt"></i>
                                                </button>
                                                <br />
                                                <button class="btn btn-sm btn-danger" onclick="removeFromWishlist(@item.BookId)">
                                                    <i class="bx bx-trash"></i> 
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center p-5 mb-0">
                        <i class="bx bx-heart"></i>
                        <p class="mt-3">Your wishlist is empty.</p>
                        <a href="/" class="btn btn-primary mt-3">Browse Books</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        function removeFromWishlist(bookId) {
            $.ajax({
                url: '/User/RemoveFromWishlist',
                type: 'POST',
                data: { id: bookId },
                success: function (response) {
                    if (response.success) {
                        const miniWishlistCount = document.getElementById('miniWishlistCount');
                        if (miniWishlistCount) {
                            miniWishlistCount.innerText = response.wishlistCount ?? '0';
                            // Show empty state without reloading the page
                            $('#cart-body').html('');
                            $('.cart-footer').remove();
                            $('.card-body').html(`
                                <div class="alert alert-info text-center p-5 mb-0">
                                    <i class="bx bx-cart"></i>
                                    <p class="mt-3">Your cart is empty.</p>
                                    <a href="/User/Home" class="btn btn-primary mt-3">Browse Books</a>
                                </div>
                            `);
                        }
                        else {
                    alert(response.message || "Could not remove item.");
                }

                        $(`#wishlist-item-${bookId}`).fadeOut(300, function () {
                            $(this).remove();
                        });

                        Swal.fire({
                            icon: "success",
                            title: "Removed from Wishlist",
                            timer: 1500,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire("Oops!", response.message || "Something went wrong.", "warning");
                    }
                },
                error: function () {
                    Swal.fire("Oops!", "Error removing from wishlist. Try again later.", "error");
                }
            });
        }

        function addToCart(bookId) {
            $.ajax({
                url: `/User/AddToCart/${bookId}`,
                type: 'POST',
                dataType: 'json',
                success: function (data) {
                    if (data.success) {
                        const miniCartCount = document.getElementById('miniCartCount');
                        if (miniCartCount) {
                            miniCartCount.innerText = data.cartCount;
                        }

                        Swal.fire({
                            icon: "success",
                            title: "Added to Cart!",
                            timer: 1500,
                            showConfirmButton: false
                        });
                    }
                },
                error: function () {
                    Swal.fire("Oops!", "Something went wrong. Try again later.", "error");
                }
            });
        }

        $(document).ready(function () {
            $.ajax({
                url: '/User/GetWishlistCount',
                type: 'GET',
                success: function () {
                    console.log("Wishlist synced successfully");
                },
                error: function (xhr, status, error) {
                    console.error("Error syncing wishlist:", error);
                }
            });
        });
    </script>
</body>
</html>
