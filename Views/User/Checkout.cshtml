@model EBook.Models.CheckoutModel

@{
    ViewData["Title"] = "Checkout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Checkout</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .checkout-card {
            margin-top: 80px;
            max-width: 800px;
            margin-left: 350px;
            margin-right: auto;
            border-radius: 12px;
            box-shadow: 0 0 12px rgba(0, 0, 0, 0.05);
            background-color: #fff;
            padding: 2rem;
            transition: box-shadow 0.3s ease;
        }

            .checkout-card:hover {
                box-shadow: 0 0 25px rgba(0, 0, 0, 0.15);
            }

        .checkout-header {
            background-color: #f8f9fa;
            font-weight: 600;
            font-size: 1.5rem;
            text-align: center;
            border-bottom: 1px solid #dee2e6;
            padding: 1rem;
            border-radius: 12px 12px 0 0;
            margin-bottom: 2rem;
        }

        .form-label {
            font-weight: 500;
        }

        .btn-primary {
            border-color: #007bff;
            background-color: #007bff;
            transition: background-color 0.3s, border-color 0.3s;
        }

            .btn-primary:hover {
                background-color: #0056b3;
                border-color: #0056b3;
            }

        .order-summary {
            background-color: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #dee2e6;
        }

            .order-summary h4 {
                color: #333;
                margin-bottom: 15px;
                border-bottom: 1px solid #dee2e6;
                padding-bottom: 10px;
            }

        .order-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .total-amount {
            font-size: 1.2rem;
            font-weight: bold;
            color: #28a745;
            border-top: 1px solid #dee2e6;
            padding-top: 10px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="checkout-card">
            <div class="checkout-header">Checkout</div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mb-4">
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="PlaceOrder" method="post">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="City" class="form-label"></label>
                        <input asp-for="City" class="form-control" />
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Complete Address</label>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="Enter your complete address"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="PaymentMethod" class="form-label">Payment Method</label>
                    <select name="PaymentMethod" id="PaymentMethod" class="form-control">
                        <option value="">-- Select Payment Method --</option>
                        <option value="COD">Cash on Delivery</option>
                        <option value="Card">Credit/Debit Card</option>
                        <option value="UPI">UPI</option>
                    </select>
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                </div>

                <!-- Order Summary Section -->
                <div class="order-summary mb-4">
                    <h5 class="mb-3">Order Summary</h5>
                    @if (Model.CartItems != null && Model.CartItems.Any())
                    {
                        foreach (var item in Model.CartItems)
                        {
                            <div class="order-item">
                                <span>@item.BookName (@item.Quantity x ₹@item.Price)</span>
                                <span>₹@(item.Quantity * item.Price)</span>
                            </div>
                        }
                        <div class="total-amount d-flex justify-content-between">
                            <span>Total Amount:</span>
                            <span>₹@Model.TotalAmount.ToString("0.00")</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-center">Your cart is empty</p>
                    }
                </div>

                @* <div class="mb-4 p-3 bg-light rounded total-section">
                    <h5 class="mb-3">Bill Summary</h5>
                    <div class="d-flex justify-content-between">
                        <span>Subtotal:</span>
                        <span>₹@Model.TotalAmount.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Shipping:</span>
                        <span>Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total Amount:</span>
                        <span class="text-success">₹@Model.TotalAmount.ToString("0.00")</span>
                    </div>
                </div> *@

                <button type="submit" class="btn btn-success btn-lg w-100 p-3 rounded-3 d-flex justify-content-center align-items-center">
                    <i class="bi bi-cart-check me-2"></i> Place Order
                </button>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>