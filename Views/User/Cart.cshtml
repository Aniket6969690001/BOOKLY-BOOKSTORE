@model List<EBook.Models.CartItem>

@{
    double totalPrice = Model.Sum(b => b.Price * b.Quantity);
    ViewData["Title"] = "My Cart";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
    body {
        background-color: #f1f5f9;
    }

    .cart-container {
        margin: 120px auto 30px auto;
        max-width: 1100px;
    }

    .card {
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
        background-color: #fff;
    }

    .cart-img {
        width: 60px;
        height: 85px;
        object-fit: cover;
        border-radius: 4px;
    }

    .quantity-control {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
    }

    .btn {
        font-size: 0.85rem;
        padding: 0.35rem 0.75rem;
        transition: 0.3s;
    }

    .cart-footer {
        text-align: right;
        font-size: 18px;
        font-weight: bold;
        color: #1e293b;
        margin-top: 20px;
    }

    .btn-add-more, .btn-checkout {
        padding: 8px 20px;
        font-size: 1rem;
    }

    .card-footer {
        border-top: 1px solid #e2e8f0;
        background-color: #fff;
        text-align: center;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
    }

        .card-footer .btn {
            margin: 5px;
        }

    @@media (max-width: 768px) {
        .cart-container {
            padding: 15px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .card-footer {
            flex-direction: column;
            align-items: center;
        }

            .card-footer .btn {
                width: 100%;
                max-width: 300px;
            }
    }
</style>

<div class="container cart-container">
    <div class="card">
        <div class="card-header bg-light fw-semibold fs-5">My Cart</div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center p-5 mb-0">
                    <i class="bx bx-cart"></i>
                    <p class="mt-3">Your cart is empty.</p>
                    <a href="/User/Home" class="btn btn-primary mt-3">Browse Books</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light text-center">
                            <tr>
                                <th>No.</th>
                                <th>Image</th>
                                <th>Book</th>
                                <th>Author</th>
                                <th>Quantity</th>
                                <th>Price (₹)</th>
                                <th>Total (₹)</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="cart-body">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                var item = Model[i];
                                <tr id="row-@item.BookId" class="text-center align-middle">
                                    <td>@(i + 1)</td>
                                    <td><img src="~/images/@item.Image" alt="@item.BookName" class="cart-img" /></td>
                                    <td>@item.BookName</td>
                                    <td>@item.AuthorName</td>
                                    <td>
                                        <div class="quantity-control">
                                            <button class="btn btn-sm btn-primary decrease-btn" data-id="@item.BookId">−</button>
                                            <span class="item-quantity" id="qty-@item.BookId">@item.Quantity</span>
                                            <button class="btn btn-sm btn-primary increase-btn" data-id="@item.BookId">+</button>
                                        </div>
                                    </td>
                                    <td>₹@item.Price</td>
                                    <td>₹@(item.Quantity * item.Price)</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger remove-from-cart-btn" data-id="@item.BookId">Remove</button>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="cart-footer">
                    Total: ₹<span id="grand-total">@totalPrice</span>
                </div>
            }
        </div>

        <div class="card-footer">
            <a href="/User/Home" class="btn btn-primary btn-add-more">Add More Books</a>
            @if (Model.Any())
            {
                <button type="button" class="btn btn-success btn-checkout"
                        onclick="location.href='@Url.Action("Checkout", "User")'">
                    Proceed to Checkout
                </button>
            }
        </div>
    </div>
</div>

<script>
     
    $(document).ready(function () {

           $(document).on('click', '.increase-btn', function (e) {
        e.preventDefault();
        var bookId = $(this).data('id');
        updateCartQuantity(bookId, true);
    });

    // Decrease quantity button
    $(document).on('click', '.decrease-btn', function (e) {
        e.preventDefault();
        var bookId = $(this).data('id');
        updateCartQuantity(bookId, false);
    });
        // Handle remove button click
    $(document).on('click', '.remove-from-cart-btn', function (e) {
        e.preventDefault();
        var bookId = $(this).data('id');
        removeFromCart(bookId);
    });

    function updateCartQuantity(bookId, isIncrease) {
        $.ajax({
            url: '/User/UpdateCartQuantity',
            type: 'POST',
            data: { id: bookId, isIncrease: isIncrease },
            success: function (response) {
                if (response.success) {
                    const item = response.updatedItem;

                    if (item.quantity > 0) {
                        // Update quantity
                        $('#qty-' + bookId).text(item.quantity);

                        // Update total price for this row
                        $('#row-' + bookId).find('td').eq(6).text(`₹${(item.quantity * item.price).toFixed(2)}`);
                    } else {
                        // If quantity is 0, remove row
                        $('#row-' + bookId).fadeOut(300, function () {
                            $(this).remove();
                        });
                    }

                    // Update grand total and cart count
                    $('#grand-total').text(response.totalPrice.toFixed(2));
                    $('#cart-count').text(response.cartCount);

                    // If cart is empty after remove
                    if (response.cartCount === 0) {
                        $('#cart-body').html('');
                        $('.cart-footer').remove();
                        $('.card-body').html(`
                            <div class="alert alert-info text-center p-5 mb-0">
                                <i class="bx bx-cart"></i>
                                <p class="mt-3">Your cart is empty.</p>
                                <a href="/User/Home" class="btn btn-primary mt-3">Browse Books</a>
                            </div>
                        `);
                    }
                } else {
                    alert(response.message || "Something went wrong.");
                }
            },
            error: function () {
                alert("Error while updating cart.");
            }
        });
    }

        // Remove from cart
        function removeFromCart(bookId) {
            $.post("/User/RemoveFromCart", { id: bookId }, function (response) {
                if (response.success) {
                    $('#row-' + bookId).fadeOut(300, function () {
                        $(this).remove();
                        $('#grand-total').text(response.totalPrice.toFixed(2));
                        $('#cart-count').text(response.cartCount);

                        if (response.cartCount === 0) {
                            // Show empty state without reloading the page
                            $('#cart-body').html('');
                            $('.cart-footer').remove();
                            $('.card-body').html(`
                                <div class="alert alert-info text-center p-5 mb-0">
                                    <i class="bx bx-cart"></i>
                                    <p class="mt-3">Your cart is empty.</p>
                                    <a href="/User/Home" class="btn btn-primary mt-3">Browse Books</a>
                                </div>
                            `);
                        }
                    });
                } else {
                    alert(response.message || "Could not remove item.");
                }
            }).fail(function () {
                alert("Error while removing item.");
            });
        }

        // Re-render cart
        function renderCartRows(items) {
            let rowsHtml = '';
            let totalPrice = 0;

            items.forEach((item, index) => {
                const rowTotal = item.price * item.quantity;
                totalPrice += rowTotal;

                rowsHtml += `
                    <tr id="row-${item.bookId}" class="text-center align-middle">
                        <td>${index + 1}</td>
                        <td><img src="/images/${item.image}" class="cart-img" alt="${item.bookName}"/></td>
                        <td>${item.bookName}</td>
                        <td>${item.authorName}</td>
                        <td>
                            <div class="quantity-control">
                                <button class="btn btn-sm btn-primary decrease-btn" data-id="${item.bookId}">−</button>
                                ${item.quantity}
                                <button class="btn btn-sm btn-primary increase-btn" data-id="${item.bookId}">+</button>
                            </div>
                        </td>
                        <td>₹${item.price}</td>
                        <td>₹${rowTotal}</td>
                        <td>
                            <button class="btn btn-sm btn-danger remove-from-cart-btn" data-id="${item.bookId}">Remove</button>
                        </td>
                    </tr>`;
            });

            $('#cart-body').html(rowsHtml);
            $('#grand-total').text(totalPrice.toFixed(2));
        }

    });
   
</script>
