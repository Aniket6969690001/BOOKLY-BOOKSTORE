@model EBook.Models.OrderConfirmationModel

@{
    ViewData["Title"] = "Order Confirmation";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .confirmation-container {
        margin: 100px auto 30px auto;
        max-width: 950px;
    }

    .card {
        border-radius: 14px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
        background-color: #fff;
        overflow: hidden;
    }

    .card-header {
        background-color: #28a745;
        color: #fff;
        font-weight: 600;
        font-size: 1.6rem;
        text-align: center;
        padding: 1.4rem;
    }

    .success-icon {
        font-size: 60px;
        color: #28a745;
        margin-bottom: 1.2rem;
    }

    .order-details {
        border-radius: 8px;
        background-color: #f9fbfc;
        padding: 1.3rem 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid #e3e6e8;
    }

    .book-img {
        width: 60px;
        height: 85px;
        object-fit: cover;
        border-radius: 5px;
        border: 1px solid #ddd;
    }

    .table th, .table td {
        vertical-align: middle !important;
    }

    .table thead {
        background-color: #f3f5f7;
    }

        .table thead th {
            font-weight: 600;
            font-size: 15px;
        }

    .table tfoot td {
        font-weight: 600;
        background-color: #f8f9fa;
    }

    .btn-continue {
        padding: 12px 30px;
        font-size: 1.1rem;
        border-radius: 8px;
    }

    .total-section {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1.4rem;
        border: 1px solid #dee2e6;
    }

        .total-section h5 {
            font-size: 1.2rem;
            font-weight: 600;
        }

    .d-flex span {
        font-size: 15px;
    }

    .text-success {
        font-weight: 600;
        font-size: 17px;
    }

    @@media (max-width: 768px) {
        .confirmation-container {
            padding: 20px;
        }

        .table-responsive {
            overflow-x: auto;
        }
    }
</style>

<div class="container confirmation-container">
    <div class="card">
        <div class="card-header">
            <i class="bi bi-check-circle-fill me-2"></i> Order Confirmation
        </div>
        <div class="card-body text-center p-4">
            <div class="success-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <h3 class="fw-bold">Thank You for Your Order!</h3>
            <p class="mb-4 text-muted">Your order has been placed successfully and is being processed.</p>

            <div class="order-details text-start">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Order ID:</strong> @Model.OrderId</p>
                        <p><strong>Name:</strong> @Model.FullName</p>
                        <p><strong>Email:</strong> @Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Order Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
                        <p><strong>Total Amount:</strong> ₹@Model.TotalAmount</p>
                    </div>
                </div>
            </div>

            <h4 class="mb-3 text-start fw-bold">Order Summary</h4>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr class="text-center">
                            <th>Image</th>
                            <th>Book</th>
                            <th>Author</th>
                            <th>Quantity</th>
                            <th>Price (₹)</th>
                            <th>Total (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr class="text-center">
                                <td><img src="~/images/@item.Image" alt="@item.BookName" class="book-img" /></td>
                                <td>@item.BookName</td>
                                <td>@item.AuthorName</td>
                                <td>@item.Quantity</td>
                                <td>₹@item.Price</td>
                                <td>₹@(item.Quantity * item.Price)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="5" class="text-end">Grand Total:</td>
                            <td class="text-center">₹@Model.TotalAmount</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-4 total-section">
                <h5>Bill Summary</h5>
                <div class="d-flex justify-content-between mt-3">
                    <span>Subtotal:</span>
                    <span>₹@Model.TotalAmount.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Shipping:</span>
                    <span>Free</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">Total Amount:</span>
                    <span class="text-success">₹@Model.TotalAmount.ToString("0.00")</span>
                </div>
            </div>

            <div class="mt-4">
                <a href="/User/Home" class="btn btn-primary btn-continue">
                    <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>
