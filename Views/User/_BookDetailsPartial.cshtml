@model EBook.Models.BookViewModel

<!-- 📚 Book Details Modal -->
<div class="modal fade" id="bookDetailsModal" tabindex="-1" aria-labelledby="bookDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content p-3">
            <div class="modal-header">
                <h5 class="modal-title" id="bookDetailsModalLabel">Book Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body d-flex flex-column flex-md-row gap-4">
                <div class="book-image-container" style="width: 500px; height: 300px; display: flex; align-items: center; justify-content: center;">
                    <img id="modalBookImage" src="/images/default-book.png" alt="Book Image" 
                         style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                </div>
                <div class="w-100">
                    <h2 id="modalBookName" class="mb-3"></h2>
                    <p><strong>Author:</strong> <span id="modalAuthorName"></span></p>
                    <p><strong>Description:</strong> <span id="modalBookDescription" class="book-description"></span></p>
                    <p class="d-none" id="modalBookFullDescription"></p>
                    <a href="#" id="readMoreBtn" class="text-primary">Read more</a>
                    <p class="mt-3"><strong>Price:</strong> ₹<span id="modalBookPrice"></span></p>

                    <div class="action-buttons mt-4 d-flex gap-2">
                        <button type="button" id="modalAddToCartBtn" class="btn btn-primary add-to-cart-btn" data-book-id="">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                        <button type="button" id="modalBuyNowBtn" class="btn btn-success">
                            <i class="bi bi-bag"></i> Buy Now
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Function to display search result as text-only dropdown
    function displaySearchResult(book) {
        var suggestionDiv = document.createElement('div');
        suggestionDiv.classList.add('search-suggestion-item', 'p-2', 'border-bottom');
        suggestionDiv.innerHTML = `
            <div class="text-only-suggestion">
                <strong>${book.bookName || book.name}</strong>
                <small class="text-muted d-block">by ${book.authorName || book.author}</small>
            </div>
        `;

        // Add click event to show book details when clicked
        suggestionDiv.addEventListener('click', function() {
            showBookDetails(book.id, book.bookName || book.name, book.authorName || book.author, 
                            book.description, book.price, book.image);
            // Close the dropdown after selection
            document.getElementById('searchSuggestions').style.display = 'none';
        });

        document.getElementById('searchSuggestions').appendChild(suggestionDiv);
    }

    // Function to show book details in modal
    function showBookDetails(id, name, author, description, price, imagePath) {
        document.getElementById('modalBookName').innerText = name || "No Title Available";
        document.getElementById('modalAuthorName').innerText = author || "Unknown Author";
        document.getElementById('modalBookDescription').innerText = description || "No description available.";
        document.getElementById('modalBookPrice').innerText = price || "N/A";
        
        // Set the book ID for the Add to Cart button
        document.getElementById('modalAddToCartBtn').setAttribute('data-book-id', id);
        
        // Set image with proper path handling
        if (imagePath) {
            debugger;
            // Ensure the path starts with /Images/
            let imageSrc = imagePath.startsWith('/') ? imagePath : '/Images/' + imagePath;
            document.getElementById('modalBookImage').src = imageSrc;
        } else {
            document.getElementById('modalBookImage').src = '/Images/default-book.png';
        }

        var modal = new bootstrap.Modal(document.getElementById('bookDetailsModal'));
        modal.show();
    }

    // Setup Add to Cart functionality for the modal button
    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('modalAddToCartBtn').addEventListener('click', function() {
            const bookId = this.getAttribute('data-book-id');
            if (bookId) {
                addToCart(bookId);
            }
        });

        document.getElementById('modalBuyNowBtn').addEventListener('click', function() {
            const bookId = document.getElementById('modalAddToCartBtn').getAttribute('data-book-id');
            if (bookId) {
                addToCart(bookId, true);
            }
        });

        // Add enhanced styling
        const style = document.createElement('style');
        style.textContent = `
            .search-suggestion-item {
                transition: background-color 0.2s;
                cursor: pointer;
            }
            .search-suggestion-item:hover {
                background-color: #f0f0f0;
            }
            .text-only-suggestion {
                padding: 4px 0;
            }
            #searchSuggestions {
                position: absolute;
                width: 100%;
                max-height: 300px;
                overflow-y: auto;
                background-color: white;
                border: 1px solid #dee2e6;
                border-top: none;
                border-radius: 0 0 4px 4px;
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                z-index: 1050;
            }
            #searchInput {
                position: relative;
            }
            .book-image-container {
                background-color: #f8f9fa;
                border-radius: 8px;
                overflow: hidden;
            }
        `;
        document.head.appendChild(style);

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            if (!event.target.closest('#searchInput') && !event.target.closest('#searchSuggestions')) {
                const suggestions = document.getElementById('searchSuggestions');
                if (suggestions) {
                    suggestions.style.display = 'none';
                }
            }
        });
    });

    // Function to add a book to cart
    function addToCart(bookId, navigateToCart = false) {
        fetch(`/User/AddToCart?id=${bookId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update cart count in UI
                updateCartCount(data.cartCount);
                
                // Show success message
                const toast = document.createElement('div');
                toast.className = 'position-fixed bottom-0 end-0 p-3';
                toast.style.zIndex = '1070';
                toast.innerHTML = `
                    <div class="toast show align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="bi bi-check-circle me-2"></i> Book added to cart successfully!
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `;
                document.body.appendChild(toast);
                
                // Remove toast after 3 seconds
                setTimeout(() => {
                    toast.remove();
                }, 3000);
                
                // Navigate to cart if requested (Buy Now button)
                if (navigateToCart) {
                    window.location.href = '/User/Cart';
                }
            } else {
                alert(data.message || 'Failed to add book to cart');
            }
        })
        .catch(error => {
            console.error('Error adding to cart:', error);
            alert('Something went wrong. Please try again.');
        });
    }

    // Function to update cart count in UI
    function updateCartCount(count) {
        const cartCountElement = document.getElementById('cartCount');
        if (cartCountElement) {
            cartCountElement.textContent = count;
        }
    }
</script>